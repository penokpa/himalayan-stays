DATABASE_URL="postgresql://user:password@localhost:5432/himalayan_stays"
DIRECT_URL="postgresql://user:password@localhost:5432/himalayan_stays"

NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Currency conversion (NPR per 1 USD). Defaults to 135 if unset.
NPR_PER_USD="135"

# Payments
STRIPE_SECRET_KEY="sk_test_..."
# Stripe webhook signing secret. Required for /api/payments/stripe/webhook.
# Get it from: Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret.
# For local dev, run `stripe listen --forward-to localhost:3000/api/payments/stripe/webhook`
# and paste the whsec_... it prints.
STRIPE_WEBHOOK_SECRET="whsec_..."
ESEWA_MERCHANT_CODE="EPAYTEST"
ESEWA_SECRET_KEY="8gBm/:&EnhH.1/q"
KHALTI_SECRET_KEY=""
KHALTI_GATEWAY_URL="https://dev.khalti.com"

# Email
RESEND_API_KEY=""
EMAIL_FROM="bookings@himalayanstays.com"

# Photo uploads (Vercel Blob — required for admin photo upload feature)
# Get a token from your Vercel project: Storage → Blob → Connect Project → .env.local
BLOB_READ_WRITE_TOKEN=""

# Cron secret for /api/cron/* endpoints. Vercel Cron sends Authorization: Bearer <secret>.
# Generate one with: openssl rand -hex 32
CRON_SECRET=""
